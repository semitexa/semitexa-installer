# Application
APP_ENV=prod
APP_DEBUG=0
APP_NAME="Semitexa App"
APP_KEY=CHANGEME
APP_PORT=8080

# Swoole
SWOOLE_HOST=0.0.0.0
SWOOLE_PORT=8080
SWOOLE_WORKER_NUM=4
SWOOLE_MAX_REQUEST=10000
SWOOLE_MAX_COROUTINE=100000
SWOOLE_LOG_FILE=var/log/swoole.log
SWOOLE_LOG_LEVEL=1

# Database
DB_DRIVER=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=semitexa
DB_USERNAME=semitexa
DB_PASSWORD=CHANGEME
DB_ROOT_PASSWORD=CHANGEME
DB_POOL_SIZE=10
DB_CHARSET=utf8mb4

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# CORS
CORS_ALLOW_ORIGIN=*
CORS_ALLOW_METHODS=GET, POST, PUT, DELETE, OPTIONS
CORS_ALLOW_HEADERS=Content-Type, Authorization
CORS_ALLOW_CREDENTIALS=false

# Async Events (0 = in-memory, 1 = RabbitMQ)
EVENTS_ASYNC=0
